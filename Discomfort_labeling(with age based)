    "# Make a copy\n",
    "df_labeled = df_score.copy()\n",
    "\n",
    "# Step 1: Compute thresholds using score distribution\n",
    "low_thr = df_labeled[\"discomfort_score\"].quantile(0.33)\n",
    "high_thr = df_labeled[\"discomfort_score\"].quantile(0.66)\n",
    "\n",
    "print(\"Low threshold:\", low_thr)\n",
    "print(\"High threshold:\", high_thr)\n",
    "\n",
    "# Step 2: Assign labels\n",
    "def label_discomfort(score):\n",
    "    if score <= low_thr:\n",
    "        return \"Comfortable\"\n",
    "    elif score <= high_thr:\n",
    "        return \"Mild_Discomfort\"\n",
    "    else:\n",
    "        return \"Severe_Discomfort\"\n",
    "\n",
    "df_labeled[\"discomfort_label\"] = df_labeled[\"discomfort_score\"].apply(label_discomfort)\n",
    "\n",
    "# Inspect result\n",
    "df_labeled[[\"window_id\", \"discomfort_score\", \"discomfort_label\"]].head()\n"

    "# -------- Scene discovery --------\n",
    "\n",
    "all_files = os.listdir(can_bus_dir)\n",
    "\n",
    "scene_ids = sorted(\n",
    "    list(set([f.split(\"_\")[0] for f in all_files if f.startswith(\"scene-\")]))\n",
    ")\n",
    "\n",
    "print(\"Total scenes found:\", len(scene_ids))\n",
    "print(\"First 5 scenes:\", scene_ids[:5])\n",
    "\n",
    "\n",
    "# -------- Helper functions --------\n",
    "\n",
    "def load_json(scene_id, suffix):\n",
    "    path = os.path.join(can_bus_dir, f\"{scene_id}_{suffix}.json\")\n",
    "    with open(path, \"r\") as f:\n",
    "        return json.load(f)\n",
    "\n",
    "\n",
    "def extract_imu_features(scene_id):\n",
    "    data = load_json(scene_id, \"ms_imu\")\n",
    "    df = pd.DataFrame(data)\n",
    "\n",
    "    df[\"longitudinal_accel\"] = df[\"linear_accel\"].apply(lambda x: x[0])\n",
    "    df[\"lateral_accel\"] = df[\"linear_accel\"].apply(lambda x: x[1])\n",
    "    df[\"yaw_rate\"] = df[\"rotation_rate\"].apply(lambda x: x[2])\n",
    "\n",
    "    return df[[\"utime\", \"longitudinal_accel\", \"lateral_accel\", \"yaw_rate\"]]\n",
    "\n",
    "\n",
    "def extract_vehicle_features(scene_id):\n",
    "    data = load_json(scene_id, \"vehicle_monitor\")\n",
    "    df = pd.DataFrame(data)\n",
    "\n",
    "    return df[\n",
    "        [\"utime\", \"vehicle_speed\", \"brake\", \"throttle\", \"steering_speed\"]\n",
    "    ]\n"
   ]
  },

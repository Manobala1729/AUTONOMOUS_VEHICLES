    "# Add Child profile\n",
    "age_profiles = {\n",
    "    \"Young\": 1.2,\n",
    "    \"Adult\": 1.0,\n",
    "    \"Child\": 0.85,\n",
    "    \"Elderly\": 0.75\n",
    "}\n",
    "\n",
    "# Base thresholds (adult reference)\n",
    "base_low = df_all[\"discomfort_score\"].quantile(0.33)\n",
    "base_high = df_all[\"discomfort_score\"].quantile(0.66)\n",
    "\n",
    "def label_by_age(score, age_group):\n",
    "    scale = age_profiles[age_group]\n",
    "    low = base_low * scale\n",
    "    high = base_high * scale\n",
    "\n",
    "    if score <= low:\n",
    "        return \"Comfortable\"\n",
    "    elif score <= high:\n",
    "        return \"Mild_Discomfort\"\n",
    "    else:\n",
    "        return \"Severe_Discomfort\"\n",
    "\n",
    "\n",
    "# Apply labels\n",
    "for age_group in age_profiles:\n",
    "    df_all[f\"discomfort_label_{age_group.lower()}\"] = df_all[\n",
    "        \"discomfort_score\"\n",
    "    ].apply(lambda x: label_by_age(x, age_group))\n",
    "\n",

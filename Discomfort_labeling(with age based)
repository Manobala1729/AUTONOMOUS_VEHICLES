    "def process_scene(scene_id, window_size=1.0):\n",
    "    \"\"\"\n",
    "    Process one nuScenes CAN bus scene and return\n",
    "    window-level discomfort annotations.\n",
    "    \"\"\"\n",
    "\n",
    "    # --- Extract features ---\n",
    "    imu_df = extract_imu_features(scene_id).sort_values(\"utime\")\n",
    "    veh_df = extract_vehicle_features(scene_id).sort_values(\"utime\")\n",
    "\n",
    "    # --- Time alignment ---\n",
    "    df = pd.merge_asof(\n",
    "        veh_df,\n",
    "        imu_df,\n",
    "        on=\"utime\",\n",
    "        direction=\"nearest\"\n",
    "    )\n",
    "\n",
    "    if len(df) < 5:\n",
    "        return None  # skip very short scenes\n",
    "\n",
    "    # --- Time normalization ---\n",
    "    df[\"time_sec\"] = (df[\"utime\"] - df[\"utime\"].iloc[0]) / 1e6\n",
    "    df[\"dt\"] = df[\"time_sec\"].diff()\n",
    "\n",
    "    # --- Jerk computation ---\n",
    "    df[\"longitudinal_jerk\"] = df[\"longitudinal_accel\"].diff() / df[\"dt\"]\n",
    "    df[\"lateral_jerk\"] = df[\"lateral_accel\"].diff() / df[\"dt\"]\n",
    "\n",
    "    df = df.dropna().reset_index(drop=True)\n",
    "\n",
    "    if len(df) < 3:\n",
    "        return None\n",
    "\n",
    "    # --- Windowing ---\n",
    "    df[\"window_id\"] = (df[\"time_sec\"] // window_size).astype(int)\n",
    "\n",
    "    df_window = df.groupby(\"window_id\").agg({\n",
    "        \"vehicle_speed\": \"mean\",\n",
    "        \"brake\": \"mean\",\n",
    "        \"throttle\": \"mean\",\n",
    "        \"steering_speed\": \"mean\",\n",
    "        \"longitudinal_accel\": \"mean\",\n",
    "        \"lateral_accel\": \"mean\",\n",
    "        \"yaw_rate\": \"mean\",\n",
    "        \"longitudinal_jerk\": \"mean\",\n",
    "        \"lateral_jerk\": \"mean\"\n",
    "    }).reset_index()\n",
    "\n",
    "    # --- Discomfort score ---\n",
    "    df_window[\"discomfort_score\"] = (\n",
    "        df_window[\"longitudinal_accel\"].abs() +\n",
    "        df_window[\"lateral_accel\"].abs() +\n",
    "        df_window[\"yaw_rate\"].abs() +\n",
    "        df_window[\"longitudinal_jerk\"].abs() +\n",
    "        df_window[\"lateral_jerk\"].abs() +\n",
    "        df_window[\"steering_speed\"].abs() * 0.01 +\n",
    "        df_window[\"brake\"] * 0.5\n",
    "    )\n",
    "\n",
    "    # --- Labeling (relative thresholds per scene) ---\n",
    "    low_thr = df_window[\"discomfort_score\"].quantile(0.33)\n",
    "    high_thr = df_window[\"discomfort_score\"].quantile(0.66)\n",
    "\n",
    "    def label_fn(x):\n",
    "        if x <= low_thr:\n",
    "            return \"Comfortable\"\n",
    "        elif x <= high_thr:\n",
    "            return \"Mild_Discomfort\"\n",
    "        else:\n",
    "            return \"Severe_Discomfort\"\n",
    "\n",
    "    df_window[\"discomfort_label\"] = df_window[\"discomfort_score\"].apply(label_fn)\n",
    "\n",
    "    # --- Add scene id ---\n",
    "    df_window[\"scene_id\"] = scene_id\n",
    "\n",
    "    return df_window\n"
   ]

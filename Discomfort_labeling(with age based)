    "# Make a copy\n",
    "df_score = df_window.copy()\n",
    "\n",
    "# Step 1: Absolute values (discomfort depends on magnitude, not direction)\n",
    "df_score[\"abs_long_accel\"] = df_score[\"longitudinal_accel\"].abs()\n",
    "df_score[\"abs_lat_accel\"] = df_score[\"lateral_accel\"].abs()\n",
    "df_score[\"abs_yaw_rate\"] = df_score[\"yaw_rate\"].abs()\n",
    "df_score[\"abs_long_jerk\"] = df_score[\"longitudinal_jerk\"].abs()\n",
    "df_score[\"abs_lat_jerk\"] = df_score[\"lateral_jerk\"].abs()\n",
    "df_score[\"abs_steering_speed\"] = df_score[\"steering_speed\"].abs()\n",
    "\n",
    "# Step 2: Heuristic discomfort score (equal weights for now)\n",
    "df_score[\"discomfort_score\"] = (\n",
    "    df_score[\"abs_long_accel\"] +\n",
    "    df_score[\"abs_lat_accel\"] +\n",
    "    df_score[\"abs_yaw_rate\"] +\n",
    "    df_score[\"abs_long_jerk\"] +\n",
    "    df_score[\"abs_lat_jerk\"] +\n",
    "    df_score[\"abs_steering_speed\"] * 0.01 +  # scaled (steering is large)\n",
    "    df_score[\"brake\"] * 0.5                  # braking matters more\n",
    ")\n",
    "\n",
    "# Inspect result\n",
    "print(\"Discomfort scores computed.\")\n",
    "df_score[[\"window_id\", \"discomfort_score\"]].head()\n"
   ]

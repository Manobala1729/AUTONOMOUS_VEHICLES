)\n    upper_red2 = np.array([180, 255, 255])\n\n    # Yellow\n    lower_yellow = np.array([15, 100, 100])\n    upper_yellow = np.array([35, 255, 255])\n\n    # Green\n    lower_green = np.array([40, 50, 50])\n    upper_green = np.array([90, 255, 255])\n\n    # Create masks\n    red_mask1 = cv2.inRange(hsv, lower_red1, upper_red1)\n    red_mask2 = cv2.inRange(hsv, lower_red2, upper_red2)\n    red_mask = red_mask1 + red_mask2\n\n    yellow_mask = cv2.inRange(hsv, lower_yellow, upper_yellow)\n    green_mask = cv2.inRange(hsv, lower_green, upper_green)\n\n    # Count pixels\n    red_pixels = np.sum(red_mask > 0)\n    yellow_pixels = np.sum(yellow_mask > 0)\n    green_pixels = np.sum(green_mask > 0)\n\n    # Determine dominant color\n    color_counts = {\n        \"Red\": red_pixels,\n        \"Yellow\": yellow_pixels,\n        \"Green\": green_pixels\n    }\n\n    dominant_color = max(color_counts, key=color_counts.get)\n\n    # If very low detection, return Unknown\n    if color_counts[dominant_color] < 20:\n        return \"Unknown\"\n\n    return dominant_color","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-22T16:31:34.465291Z","iopub.execute_input":"2026-02-22T16:31:34.465580Z","iopub.status.idle":"2026-02-22T16:31:34.473726Z","shell.execute_reply.started":"2026-02-22T16:31:34.465552Z","shell.execute_reply":"2026-02-22T16:31:34.472956Z"}},"outputs":[],"execution_count":4},{"cell_type":"code","source":"def detect_objects(image):\n    results = model(image)[0]\n    detections = []\n    image_height, image_width = image.shape[:2]\n    \n    for box in results.boxes:\n        cls_id = int(box.cls[0])\n        class_name = results.names[cls_id]\n        confidence = float(box.conf[0])\n        \n        if class_name in SAFETY_CLASSES:\n            bbox = box.xyxy[0].tolist()\n            position = get_position(bbox, image_width)\n            \n            detection_entry = {\n                \"class\": class_name,\n                \"confidence\"
0 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":2},{"cell_type":"code","source":"# ===============================\n# CELL 3: Perception Module\n# ===============================\n\n# Safety-critical classes (COCO names)\nSAFETY_CLASSES = [\n    \"person\",\n    \"car\",\n    \"bus\",\n    \"truck\",\n    \"bicycle\",\n    \"motorcycle\",\n    \"traffic light\"\n]\n\ndef get_position(bbox, image_width):\n    x1, y1, x2, y2 = bbox\n    center_x = (x1 + x2) / 2\n    \n    if center_x < image_width / 3:\n        return \"Left\"\n    elif center_x < 2 * image_width / 3:\n        return \"Center\"\n    else:\n        return \"Right\"\n\ndef detect_objects(image):\n    results = model(image)[0]\n    detections = []\n    image_height, image_width = image.shape[:2]\n    \n    for box in results.boxes:\n        cls_id = int(box.cls[0])\n        class_name = results.names[cls_id]\n        confidence = float(box.conf[0])\n        \n        # Filter only safety-relevant objects\n        if class_name in SAFETY_CLASSES:\n            bbox = box.xyxy[0].tolist()\n            position = get_position(bbox, image_width)\n            \n            detections.append({\n                \"class\": class_name,\n                \"confidence\": round(confidence, 3),\n                \"bbox\": bbox,\n                \"position\": position\n            })\n    \n    return detections\n\n\n# ----------- TEST PERCEPTION MODULE -----------\n\ndetections = detect_objects(image_rgb)\n\nprint(\"Structured Detections:\\n\")\nfor det in detections:\n    print(det)\n\n# Show annotated image\nannotated = model(image_rgb)[0].plot()\nannotated_rgb = cv2.cvtColor(annotated, cv2.COLOR_BGR2RGB)\n\nplt.figure(figsize=(10,6))\nplt.imshow(annotated_rgb)\nplt.axis(\"off\")\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-22T16:31:34.276592Z","iopub.execute_input":"2026-02-22T16:31:34.276829Z","iopub.status.idle":"2026-02-22T16:31:34.463656Z","shell.execute_re
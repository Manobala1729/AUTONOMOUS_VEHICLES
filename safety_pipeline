    "# ===============================\n",
    "# CELL 3: Perception Module\n",
    "# ===============================\n",
    "\n",
    "# Safety-critical classes (COCO names)\n",
    "SAFETY_CLASSES = [\n",
    "    \"person\",\n",
    "    \"car\",\n",
    "    \"bus\",\n",
    "    \"truck\",\n",
    "    \"bicycle\",\n",
    "    \"motorcycle\",\n",
    "    \"traffic light\"\n",
    "]\n",
    "\n",
    "def get_position(bbox, image_width):\n",
    "    x1, y1, x2, y2 = bbox\n",
    "    center_x = (x1 + x2) / 2\n",
    "    \n",
    "    if center_x < image_width / 3:\n",
    "        return \"Left\"\n",
    "    elif center_x < 2 * image_width / 3:\n",
    "        return \"Center\"\n",
    "    else:\n",
    "        return \"Right\"\n",
    "\n",
    "def detect_objects(image):\n",
    "    results = model(image)[0]\n",
    "    detections = []\n",
    "    image_height, image_width = image.shape[:2]\n",
    "    \n",
    "    for box in results.boxes:\n",
    "        cls_id = int(box.cls[0])\n",
    "        class_name = results.names[cls_id]\n",
    "        confidence = float(box.conf[0])\n",
    "        \n",
    "        # Filter only safety-relevant objects\n",
    "        if class_name in SAFETY_CLASSES:\n",
    "            bbox = box.xyxy[0].tolist()\n",
    "            position = get_position(bbox, image_width)\n",
    "            \n",
    "            detections.append({\n",
    "                \"class\": class_name,\n",
    "                \"confidence\": round(confidence, 3),\n",
    "                \"bbox\": bbox,\n",
    "                \"position\": position\n",
    "            })\n",
    "    \n",
    "    return detections\n",
    "\n",
    "\n",
    "# ----------- TEST PERCEPTION MODULE -----------\n",
    "\n",
    "detections = detect_objects(image_rgb)\n",
    "\n",
    "print(\"Structured Detections:\\n\")\n",
    "for det in detections:\n",
    "    print(det)\n",
    "\n",
    "# Show annotated image\n",
    "annotated = model(image_rgb)[0].plot()\n",
    "annotated_rgb = cv2.cvtColor(annotated, cv2.COLOR_BGR2RGB)\n",
    "\n",
    "plt.figure(figsize=(10,6))\n",
    "plt.imshow(annotated_rgb)\n",
    "plt.axis(\"off\")\n",
    "plt.show()"
   ]

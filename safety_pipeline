    "# ===============================\n",
    "# CELL 7: Add Proximity Classification\n",
    "# ===============================\n",
    "\n",
    "def estimate_proximity(bbox, image_height):\n",
    "    x1, y1, x2, y2 = bbox\n",
    "    height = y2 - y1\n",
    "    rel_h = height / image_height\n",
    "\n",
    "    if rel_h >= T_close:\n",
    "        return \"Close\"\n",
    "    elif rel_h >= T_far:\n",
    "        return \"Medium\"\n",
    "    else:\n",
    "        return \"Far\"\n",
    "\n",
    "\n",
    "def detect_objects_with_proximity(image):\n",
    "    results = model(image)[0]\n",
    "    detections = []\n",
    "    image_height, image_width = image.shape[:2]\n",
    "    \n",
    "    for box in results.boxes:\n",
    "        cls_id = int(box.cls[0])\n",
    "        class_name = results.names[cls_id]\n",
    "        confidence = float(box.conf[0])\n",
    "        \n",
    "        if class_name in SAFETY_CLASSES:\n",
    "            bbox = box.xyxy[0].tolist()\n",
    "            position = get_position(bbox, image_width)\n",
    "            proximity = estimate_proximity(bbox, image_height)\n",
    "            \n",
    "            detection_entry = {\n",
    "                \"class\": class_name,\n",
    "                \"confidence\": round(confidence, 3),\n",
    "                \"bbox\": bbox,\n",
    "                \"position\": position,\n",
    "                \"proximity\": proximity\n",
    "            }\n",
    "\n",
    "            # Traffic light color detection\n",
    "            if class_name == \"traffic light\":\n",
    "                color = detect_traffic_light_color(image, bbox)\n",
    "                detection_entry[\"traffic_light_color\"] = color\n",
    "\n",
    "            detections.append(detection_entry)\n",
    "    \n",
    "    return detections\n",
    "\n",

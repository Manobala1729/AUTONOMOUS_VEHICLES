    "# ===============================\n",
    "# CELL 8: Risk Assessment Engine\n",
    "# ===============================\n",
    "\n",
    "def evaluate_safety(detections):\n",
    "\n",
    "    severity_hierarchy = {\n",
    "        \"Safe\": 0,\n",
    "        \"Risky\": 1,\n",
    "        \"Unsafe\": 2\n",
    "    }\n",
    "\n",
    "    current_severity = 0  # Start as Safe\n",
    "\n",
    "    for det in detections:\n",
    "        obj = det[\"class\"]\n",
    "        prox = det[\"proximity\"]\n",
    "        pos = det[\"position\"]\n",
    "\n",
    "        # ------------------------\n",
    "        # RULE 1: Pedestrian\n",
    "        # ------------------------\n",
    "        if obj == \"person\":\n",
    "            if prox == \"Close\" and pos == \"Center\":\n",
    "                current_severity = max(current_severity, severity_hierarchy[\"Unsafe\"])\n",
    "            elif prox == \"Medium\":\n",
    "                current_severity = max(current_severity, severity_hierarchy[\"Risky\"])\n",
    "\n",
    "        # ------------------------\n",
    "        # RULE 2: Cyclist / Motorcycle\n",
    "        # ------------------------\n",
    "        elif obj in [\"bicycle\", \"motorcycle\"]:\n",
    "            if prox == \"Close\":\n",
    "                current_severity = max(current_severity, severity_hierarchy[\"Unsafe\"])\n",
    "            elif prox == \"Medium\":\n",
    "                current_severity = max(current_severity, severity_hierarchy[\"Risky\"])\n",
    "\n",
    "        # ------------------------\n",
    "        # RULE 3: Lead Vehicle\n",
    "        # ------------------------\n",
    "        elif obj in [\"car\", \"bus\", \"truck\"]:\n",
    "            if prox == \"Close\" and pos == \"Center\":\n",
    "                current_severity = max(current_severity, severity_hierarchy[\"Risky\"])\n",
    "\n",
    "        # ------------------------\n",
    "        # RULE 4: Traffic Light\n",
    "        # ------------------------\n",
    "        elif obj == \"traffic light\":\n",
    "            color = det.get(\"traffic_light_color\", \"Unknown\")\n",
    "\n",
    "            if color == \"Red\" and pos == \"Center\":\n",
    "                current_severity = max(current_severity, severity_hierarchy[\"Unsafe\"])\n",
    "            elif color == \"Yellow\":\n",
    "                current_severity = max(current_severity, severity_hierarchy[\"Risky\"])\n",
    "\n",
    "    # Reverse lookup final label\n",
    "    for label, value in severity_hierarchy.items():\n",
    "        if value == current_severity:\n",
    "            return label\n",
    "\n",
    "\n",
    "# ----------- TEST RISK ENGINE -----------\n",
    "\n",
    "risk_status = evaluate_safety(detections_test)\n",
    "\n",
    "print(\"Final Safety Status:\", risk_status)"

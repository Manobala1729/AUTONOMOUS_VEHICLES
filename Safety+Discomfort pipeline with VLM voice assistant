    "import gradio as gr\n",
    "\n",
    "def format_debug(\n",
    "    safety_output,\n",
    "    discomfort_output,\n",
    "    sensor_input,\n",
    "    speed_state,\n",
    "    braking_state,\n",
    "    motion\n",
    "):\n",
    "    text = \"\"\n",
    "\n",
    "    # ------------------------------\n",
    "    # SAFETY\n",
    "    # ------------------------------\n",
    "    text += \"🚗 SAFETY ANALYSIS\\n\"\n",
    "    text += f\"Status: {safety_output.get('safety_status','')}\\n\\n\"\n",
    "\n",
    "    text += \"Reasons:\\n\"\n",
    "    for r in safety_output.get(\"reasons\", []):\n",
    "        text += f\"• {r}\\n\"\n",
    "\n",
    "    text += \"\\n------------------------------\\n\"\n",
    "\n",
    "    # ------------------------------\n",
    "    # DISCOMFORT\n",
    "    # ------------------------------\n",
    "    text += \"🧠 DISCOMFORT ANALYSIS\\n\"\n",
    "    text += f\"Level: {discomfort_output.get('discomfort_label','')}\\n\\n\"\n",
    "\n",
    "    text += \"Top Factors:\\n\"\n",
    "    for f in discomfort_output.get(\"top_discomfort_factors\", []):\n",
    "        val = f.get(\"impact\", abs(f.get(\"shap_value\", 0)))\n",
    "        text += f\"• {f['feature']} → {round(val,3)}\\n\"\n",
    "\n",
    "    text += \"\\n------------------------------\\n\"\n",
    "\n",
    "    # ------------------------------\n",
    "    # OBJECTS\n",
    "    # ------------------------------\n",
    "    text += \"👁️ DETECTED OBJECTS\\n\"\n",
    "    for obj in safety_output.get(\"detections\", []):\n",
    "        text += f\"• {obj['class']} ({obj['position']}, {obj['proximity']})\\n\"\n",
    "\n",
    "    text += \"\\n------------------------------\\n\"\n",
    "\n",
    "    # ------------------------------\n",
    "    # SENSOR\n",
    "    # ------------------------------\n",
    "    text += \"📊 SENSOR VALUES\\n\"\n",
    "    for k, v in sensor_input.items():\n",
    "        text += f\"• {k}: {v}\\n\"\n",
    "\n",
    "    text += \"\\n------------------------------\\n\"\n",
    "\n",
    "    # ------------------------------\n",
    "    # VEHICLE STATE\n",
    "    # ------------------------------\n",
    "    text += \"⚙️ VEHICLE STATE\\n\"\n",
    "    text += f\"• Speed: {speed_state}\\n\"\n",
    "    text += f\"• Braking: {braking_state}\\n\"\n",
    "    text += f\"• Motion: {motion}\\n\"\n",
    "\n",
    "    return text\n",
    "\n",

    "# ===============================\n",
    "# FINAL INTEGRATION PIPELINE\n",
    "# ===============================\n",
    "\n",
    "from PIL import Image\n",
    "\n",
    "# ------------------------------\n",
    "# STEP 1: INPUTS\n",
    "# ------------------------------\n",
    "\n",
    "# Use your existing image\n",
    "image_input = img_rgb\n",
    "\n",
    "# Sensor input (modify as needed)\n",
    "sensor_input = {\n",
    "    \"vehicle_speed\": 5,\n",
    "    \"brake\": 0.0,\n",
    "    \"throttle\": 0.5,\n",
    "    \"steering_speed\": 0.2,\n",
    "    \"longitudinal_accel\": 0.3,\n",
    "    \"lateral_accel\": 0.2,\n",
    "    \"yaw_rate\": 0.1,\n",
    "    \"longitudinal_jerk\": 0.2,\n",
    "    \"lateral_jerk\": 0.1\n",
    "}\n",
    "\n",
    "# ------------------------------\n",
    "# STEP 2: SAFETY PIPELINE\n",
    "# ------------------------------\n",
    "safety_output = run_safety_pipeline(image_input, sensor_input)\n",
    "\n",
    "print(\"\\n===== SAFETY OUTPUT =====\")\n",
    "print(\"Decision:\", safety_output[\"safety_status\"])\n",
    "for r in safety_output[\"reasons\"]:\n",
    "    print(\"-\", r)\n",
    "\n",
    "# ------------------------------\n",
    "# STEP 3: DISCOMFORT PIPELINE\n",
    "# ------------------------------\n",
    "discomfort_output = run_discomfort_pipeline(sensor_input)\n",
    "\n",
    "print(\"\\n===== DISCOMFORT OUTPUT =====\")\n",
    "print(\"Label:\", discomfort_output[\"discomfort_label\"])\n",
    "for f in discomfort_output[\"top_discomfort_factors\"]:\n",
    "    print(\"-\", f)\n",
    "\n",
    "# ------------------------------\n",
    "# STEP 4: BUILD VLM PROMPT\n",
    "# ------------------------------\n",
    "vlm_prompt = build_vlm_prompt(safety_output, discomfort_output)\n",
    "\n",
    "# Convert image\n",
    "image_pil = Image.fromarray(image_input)\n",
    "\n",
    "conversation = [\n",
    "    {\n",
    "        \"role\": \"user\",\n",
    "        \"content\": [\n",
    "            {\"type\": \"image\"},\n",
    "            {\"type\": \"text\", \"text\": vlm_prompt}\n",
    "        ]\n",
    "    }\n",
    "]\n",
    "\n",
    "text_prompt = processor.apply_chat_template(\n",
    "    conversation,\n",
    "    add_generation_prompt=True\n",
    ")\n",
    "\n",
    "inputs = processor(\n",
    "    images=image_pil,\n",
    "    text=text_prompt,\n",
    "    return_tensors=\"pt\"\n",
    ").to(model_vlm.device)\n",
    "\n",
    "# ------------------------------\n",
    "# STEP 5: VLM GENERATION\n",
    "# ------------------------------\n",
    "with torch.no_grad():\n",
    "    output = model_vlm.generate(\n",
    "        **inputs,\n",
    "        max_new_tokens=200\n",
    "    )\n",
    "\n",
    "vlm_output = processor.decode(output[0], skip_special_tokens=True)\n",
    "\n",
    "# Clean output\n",
    "final_text = vlm_output.split(\"ASSISTANT:\")[-1].strip()\n",
    "\n",
    "print(\"\\n===== FINAL VLM EXPLANATION =====\\n\")\n",
    "print(final_text)\n",
    "\n",
    "# ------------------------------\n",
    "# STEP 6: OPTIONAL VOICE OUTPUT\n",
    "# ------------------------------\n",
    "try:\n",
    "    tts = gTTS(final_text)\n",
    "    tts.save(\"final_output.mp3\")\n",
    "    display(Audio(\"final_output.mp3\"))\n",
    "except:\n",
    "    print(\"⚠️ Audio generation skipped\")"

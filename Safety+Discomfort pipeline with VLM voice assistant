    "# ===============================\n",
    "# FINAL RULE ENGINE (REFINED)\n",
    "# ===============================\n",
    "\n",
    "def evaluate_safety_rules(detections, sensor):\n",
    "\n",
    "    # ------------------------------\n",
    "    # Extract vehicle state\n",
    "    # ------------------------------\n",
    "    speed = sensor.get(\"vehicle_speed\", 0)\n",
    "    brake = sensor.get(\"brake\", 0)\n",
    "    throttle = sensor.get(\"throttle\", 0)\n",
    "    accel = sensor.get(\"longitudinal_accel\", 0)\n",
    "\n",
    "    is_moving = speed > 5\n",
    "    is_fast = speed > 40\n",
    "    is_braking = brake > 0.3\n",
    "    is_accelerating = throttle > 0.4 or accel > 0.3\n",
    "\n",
    "    # ------------------------------\n",
    "    # Severity levels\n",
    "    # ------------------------------\n",
    "    severity_map = {\"Safe\": 0, \"Risky\": 1, \"Unsafe\": 2}\n",
    "    current_level = 0\n",
    "    reasons = set()  #avoid duplicates\n",
    "\n",
    "    # ------------------------------\n",
    "    # OBJECT-LEVEL RULES\n",
    "    # ------------------------------\n",
    "    for det in detections:\n",
    "\n",
    "        obj = det[\"class\"]\n",
    "        prox = det[\"proximity\"]\n",
    "        pos = det[\"position\"]\n",
    "\n",
    "        # =====================================\n",
    "        # 1. Pedestrian (TTC-aware)\n",
    "        # =====================================\n",
    "        if obj == \"person\":\n",
    "\n",
    "            if prox == \"Close\" and pos == \"Center\":\n",
    "\n",
    "                if is_moving:\n",
    "                    current_level = max(current_level, 2)\n",
    "                    reasons.add(\"Pedestrian very close in driving path while moving → high collision risk\")\n",
    "\n",
    "                else:\n",
    "                    current_level = max(current_level, 1)\n",
    "                    reasons.add(\"Pedestrian close ahead but vehicle stationary\")\n",
    "\n",
    "            elif prox == \"Medium\" and pos == \"Center\":\n",
    "\n",
    "                if is_fast:\n",
    "                    current_level = max(current_level, 2)\n",
    "                    reasons.add(\"High speed with pedestrian ahead → insufficient stopping distance\")\n",
    "\n",
    "                else:\n",
    "                    current_level = max(current_level, 1)\n",
    "                    reasons.add(\"Pedestrian ahead at moderate distance\")\n",
    "\n",
    "        # =====================================\n",
    "        # 2. Cyclist / Motorcycle\n",
    "        # =====================================\n",
    "        elif obj in [\"bicycle\", \"motorcycle\"]:\n",
    "\n",
    "            if prox == \"Close\" and is_moving:\n",
    "                current_level = max(current_level, 2)\n",
    "                reasons.add(\"Very close vulnerable road user while moving\")\n",
    "\n",
    "            elif prox == \"Medium\" and pos == \"Center\":\n",
    "                current_level = max(current_level, 1)\n",
    "                reasons.add(\"Cyclist in path at moderate distance\")\n",
    "\n",
    "        # =====================================\n",
    "        # 3. Lead Vehicle (Rear-end risk)\n",
    "        # =====================================\n",
    "        elif obj in [\"car\", \"bus\", \"truck\"]:\n",
    "\n",
    "            if prox == \"Close\" and pos == \"Center\":\n",
    "\n",
    "                if is_fast and not is_braking:\n",
    "                    current_level = max(current_level, 2)\n",
    "                    reasons.add(\"Close lead vehicle + high speed + no braking → rear-end collision risk\")\n",
    "\n",
    "                elif is_moving:\n",
    "                    current_level = max(current_level, 1)\n",
    "                    reasons.add(\"Following vehicle closely in same lane\")\n",
    "\n",
    "            elif prox == \"Medium\" and pos == \"Center\" and is_fast:\n",
    "                current_level = max(current_level, 1)\n",
    "                reasons.add(\"Moderate gap but high speed\")\n",
    "\n",
    "        # =====================================\n",
    "        # 4. Traffic Light (State-aware)\n",
    "        # =====================================\n",
    "        elif obj == \"traffic light\":\n",
    "\n",
    "            color = det.get(\"traffic_light_color\", \"Unknown\")\n",
    "\n",
    "            if color == \"Red\" and pos == \"Center\":\n",
    "\n",
    "                if is_moving and not is_braking:\n",
    "                    current_level = max(current_level, 2)\n",
    "                    reasons.add(\"Red light ahead but vehicle not slowing → violation risk\")\n",
    "\n",
    "                elif is_moving and is_braking:\n",
    "                    current_level = max(current_level, 1)\n",
    "                    reasons.add(\"Red light ahead and controlled braking\")\n",
    "\n",
    "            elif color == \"Yellow\":\n",
    "\n",
    "                if is_fast and not is_braking:\n",
    "                    current_level = max(current_level, 2)\n",
    "                    reasons.add(\"Yellow light + high speed → unsafe decision zone\")\n",
    "\n",
    "                elif is_moving:\n",
    "                    current_level = max(current_level, 1)\n",
    "                    reasons.add(\"Yellow light caution\")\n",
    "\n",
    "    # ------------------------------\n",
    "    # GLOBAL RULES (OUTSIDE LOOP)\n",
    "    # ------------------------------\n",
    "\n",
    "    # 5. Dense traffic (context-aware)\n",
    "    if len(detections) >= 4:\n",
    "\n",
    "        if is_moving and is_fast:\n",
    "            current_level = max(current_level, 2)\n",
    "            reasons.add(\"Dense traffic with high speed → high situational risk\")\n",
    "\n",
    "        elif is_moving:\n",
    "            current_level = max(current_level, 1)\n",
    "            reasons.add(\"Dense traffic environment → requires caution\")\n",
    "\n",
    "    # 6. Aggressive driving behavior\n",
    "    if is_fast and is_accelerating:\n",
    "        current_level = max(current_level, 1)\n",
    "        reasons.add(\"High speed with acceleration → reduced reaction time\")\n",
    "\n",
    "    # ------------------------------\n",
    "    # Final label\n",
    "    # ------------------------------\n",
    "    for label, value in severity_map.items():\n",
    "        if value == current_level:\n",
    "            final_status = label\n",
    "\n",
    "    if not reasons:\n",
    "        reasons.add(\"Driving conditions stable and controlled\")\n",
    "\n",
    "    return final_status, list(reasons)"
   ]

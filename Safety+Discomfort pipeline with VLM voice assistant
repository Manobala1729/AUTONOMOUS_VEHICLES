    "import gradio as gr\n",
    "import torch\n",
    "from PIL import Image\n",
    "\n",
    "# ===============================\n",
    "# SIMPLE VLM WITH QUESTION\n",
    "# ===============================\n",
    "def simple_vlm_explainer(image, question):\n",
    "\n",
    "    if image is None:\n",
    "        return \"Please upload an image.\"\n",
    "\n",
    "    if question is None or question.strip() == \"\":\n",
    "        question = \"Explain the situation.\"\n",
    "\n",
    "    img = Image.fromarray(image).convert(\"RGB\")\n",
    "\n",
    "    prompt = f\"\"\"\n",
    "USER: <image>\n",
    "You are an autonomous driving assistant helping a visually challenged passenger.\n",
    "\n",
    "User Question:\n",
    "{question}\n",
    "\n",
    "Instructions:\n",
    "- Answer the question clearly\n",
    "- Describe the scene\n",
    "- Mention any risks if present\n",
    "- Keep explanation simple and helpful\n",
    "\n",
    "ASSISTANT:\n",
    "\"\"\"\n",
    "\n",
    "    inputs = processor(\n",
    "        text=prompt,\n",
    "        images=img,\n",
    "        return_tensors=\"pt\"\n",
    "    ).to(model_vlm.device)\n",
    "\n",
    "    with torch.no_grad():\n",
    "        output = model_vlm.generate(\n",
    "            **inputs,\n",
    "            max_new_tokens=150\n",
    "        )\n",
    "\n",
    "    output_text = processor.decode(output[0], skip_special_tokens=True)\n",
    "    final_text = output_text.split(\"ASSISTANT:\")[-1].strip()\n",
    "\n",
    "    return final_text\n",
    "\n",
    "\n",
    "# ===============================\n",
    "# UI DESIGN\n",
    "# ===============================\n",
    "with gr.Blocks(theme=gr.themes.Soft()) as demo:\n",
    "\n",
    "    gr.Markdown(\"## 🧠 VLM-Only Assistant (Baseline with Question)\")\n",
    "\n",
    "    with gr.Row():\n",
    "\n",
    "        # LEFT\n",
    "        with gr.Column():\n",
    "            image = gr.Image(label=\"Driving Scene\")\n",
    "            question = gr.Textbox(label=\"Ask your question\")\n",
    "            btn = gr.Button(\"Analyze\")\n",
    "\n",
    "        # RIGHT\n",
    "        with gr.Column():\n",
    "            output = gr.Textbox(\n",
    "                label=\"VLM Response\",\n",
    "                lines=15\n",
    "            )\n",
    "\n",
    "    btn.click(\n",
    "        fn=simple_vlm_explainer,\n",
    "        inputs=[image, question],\n",
    "        outputs=[output]\n",
    "    )\n",
    "\n",
    "demo.launch()"
   ]

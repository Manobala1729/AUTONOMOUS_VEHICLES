    "        rel_h = (y2 - y1) / image_height\n",
    "        rel_heights.append(rel_h)\n",
    "\n",
    "    if len(rel_heights) > 0:\n",
    "        T_far = np.percentile(rel_heights, 33)\n",
    "        T_close = np.percentile(rel_heights, 66)\n",
    "    else:\n",
    "        T_far, T_close = 0.05, 0.15\n",
    "\n",
    "    # ------------------------------\n",
    "    # STEP 3: Enrich Detections\n",
    "    # ------------------------------\n",
    "    enriched_detections = []\n",
    "\n",
    "    for det in base_detections:\n",
    "\n",
    "        bbox = det[\"bbox\"]\n",
    "        x1, y1, x2, y2 = bbox\n",
    "        rel_h = (y2 - y1) / image_height\n",
    "\n",

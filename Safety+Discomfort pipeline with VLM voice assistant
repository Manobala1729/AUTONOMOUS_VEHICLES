    "# ===============================\n",
    "# CELL 3C: TRAFFIC LIGHT COLOR\n",
    "# ===============================\n",
    "\n",
    "def detect_traffic_light_color(image, bbox):\n",
    "    x1, y1, x2, y2 = map(int, bbox)\n",
    "    roi = image[y1:y2, x1:x2]\n",
    "\n",
    "    if roi.size == 0:\n",
    "        return \"Unknown\"\n",
    "\n",
    "    hsv = cv2.cvtColor(roi, cv2.COLOR_RGB2HSV)\n",
    "    height = hsv.shape[0]\n",
    "\n",
    "    # ---------- Method 1: Brightness segmentation ----------\n",
    "    top = hsv[0:height//3, :, :]\n",
    "    middle = hsv[height//3:2*height//3, :, :]\n",
    "    bottom = hsv[2*height//3:height, :, :]\n",
    "\n",
    "    brightness_values = {\n",
    "        \"Red\": np.mean(top[:, :, 2]),\n",
    "        \"Yellow\": np.mean(middle[:, :, 2]),\n",
    "        \"Green\": np.mean(bottom[:, :, 2])\n",
    "    }\n",
    "\n",
    "    brightness_color = max(brightness_values, key=brightness_values.get)\n",
    "\n",
    "    # ---------- Method 2: HSV dominant hue ----------\n",
    "    bright_mask = hsv[:, :, 2] > 150\n",
    "    h_values = hsv[:, :, 0][bright_mask]\n",
    "\n",
    "    if len(h_values) > 10:\n",
    "        red_pixels = np.sum((h_values < 10) | (h_values > 170))\n",
    "        yellow_pixels = np.sum((h_values >= 20) & (h_values <= 35))\n",
    "        green_pixels = np.sum((h_values >= 40) & (h_values <= 85))\n",
    "\n",
    "        hue_counts = {\n",
    "            \"Red\": red_pixels,\n",
    "            \"Yellow\": yellow_pixels,\n",
    "            \"Green\": green_pixels\n",
    "        }\n",
    "\n",
    "        hue_color = max(hue_counts, key=hue_counts.get)\n",
    "    else:\n",
    "        hue_color = brightness_color\n",
    "\n",
    "    # ---------- Fusion ----------\n",
    "    if brightness_color == hue_color:\n",
    "        return brightness_color\n",
    "    else:\n",
    "        return hue_color"
   ]

    "# ===============================\n",
    "# CELL 2: DISCOMFORT PIPELINE\n",
    "# ===============================\n",
    "\n",
    "# ---- Load Model ----\n",
    "MODEL_PATH = \"/kaggle/input/models/manobala12345/discomfort-predictions/pytorch/default/1/driving_discomfort_app/discomfort_rf_model.pkl\"\n",
    "ENCODER_PATH = \"/kaggle/input/models/manobala12345/discomfort-predictions/pytorch/default/1/driving_discomfort_app/label_encoder.pkl\"\n",
    "\n",
    "model_discomfort = joblib.load(MODEL_PATH)\n",
    "label_encoder = joblib.load(ENCODER_PATH)\n",
    "\n",
    "print(\"✅ Discomfort model loaded\")\n",
    "\n",
    "# ---- SHAP Explainer ----\n",
    "explainer = shap.TreeExplainer(model_discomfort)\n",
    "\n",
    "# ---- Feature List ----\n",
    "features = [\n",
    "    \"vehicle_speed\",\n",
    "    \"brake\",\n",
    "    \"throttle\",\n",
    "    \"steering_speed\",\n",
    "    \"longitudinal_accel\",\n",
    "    \"lateral_accel\",\n",
    "    \"yaw_rate\",\n",
    "    \"longitudinal_jerk\",\n",
    "    \"lateral_jerk\"\n",
    "]\n",
    "\n",
    "# ===============================\n",
    "# FUNCTION: RUN DISCOMFORT PIPELINE\n",
    "# ===============================\n",
    "def run_discomfort_pipeline(sensor_input_dict):\n",
    "    \"\"\"\n",
    "    sensor_input_dict = {\n",
    "        \"vehicle_speed\": float,\n",
    "        \"brake\": float,\n",
    "        ...\n",
    "    }\n",
    "    \"\"\"\n",
    "\n",
    "    # Convert to DataFrame\n",
    "    df_input = pd.DataFrame([sensor_input_dict])\n",
    "\n",
    "    # ---- Prediction ----\n",
    "    pred = model_discomfort.predict(df_input)[0]\n",
    "    label = label_encoder.inverse_transform([pred])[0]\n",
    "\n",
    "    # ---- SHAP ----\n",
    "    shap_values = explainer.shap_values(df_input)\n",
    "    shap_array = np.array(shap_values)\n",
    "\n",
    "    if shap_array.ndim == 3:\n",
    "        shap_instance = shap_array[0, :, pred]\n",
    "    elif isinstance(shap_values, list):\n",
    "        shap_instance = shap_values[pred][0]\n",
    "    else:\n",
    "        shap_instance = shap_array[0]\n",
    "\n",
    "    shap_instance = np.array(shap_instance).flatten()\n",
    "\n",
    "    shap_df = pd.DataFrame({\n",
    "        \"feature\": features,\n",
    "        \"shap_value\": shap_instance\n",
    "    })\n",
    "\n",
    "    # Only positive contributors\n",
    "    shap_df = shap_df[shap_df[\"shap_value\"] > 0]\n",
    "    shap_df = shap_df.sort_values(by=\"shap_value\", ascending=False)\n",
    "\n",
    "    top_factors = shap_df.head(3).to_dict(orient=\"records\")\n",
    "\n",
    "    # ---- Output Structure (IMPORTANT FOR INTEGRATION) ----\n",
    "    output = {\n",
    "        \"discomfort_label\": label,\n",
    "        \"top_discomfort_factors\": top_factors,\n",
    "        \"raw_shap\": shap_df\n",
    "    }\n",
    "\n",
    "    return output"
   ]

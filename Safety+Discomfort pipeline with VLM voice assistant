on = \"Decelerating\"\n    else:\n        motion = \"Stable motion\"\n\n    # ===============================\n    # FINAL PROMPT\n    # ===============================\n    final_prompt = f\"\"\"\nYou are an intelligent driving assistant for a visually challenged passenger.\n\nYour role is to EXPLAIN the situation using system outputs.\nDO NOT change or recompute decisions.\n\n----------------------------------------\n👤 USER QUESTION\n----------------------------------------\n{question}\n\n----------------------------------------\n🚗 SAFETY PIPELINE OUTPUT\n----------------------------------------\nSafety Status: {rule_decision}\n\nReasons:\n{rule_reasons}\n\n----------------------------------------\n🧠 DISCOMFORT OUTPUT\n----------------------------------------\nDiscomfort Level: {discomfort_label}\n\nKey Factors:\n{discomfort_text}\n\n----------------------------------------\n👁️ SCENE OBJECTS\n----------------------------------------\n{perception_text}\n\n----------------------------------------\n📊 VEHICLE STATE\n----------------------------------------\nSpeed: {speed_state}\nBraking: {braking_state}\nMotion: {motion}\n\n----------------------------------------\n🧾 INSTRUCTIONS\n----------------------------------------\n1. Answer the USER QUESTION directly\n2. Use safety decision as ground truth\n3. Use discomfort factors for explanation\n4. Be descriptive (for blind user)\n5. Do NOT reclassify safety\n\n----------------------------------------\n🎯 FORMAT\n----------------------------------------\nAnswer:\n<Direct answer>\n\nDetailed Explanation:\n<Explain clearly>\n\"\"\"\n\n    # ===============================\n    # VLM\n    # ===============================\n    img = Image.fromarray(image).convert(\"RGB\")\n\n    conversation = [{\n        \"role\": \"user\",\n        \"content\": [\n            {\"type\": \"image\"},\n            {\"type\": \"text\", \"text\": final_prompt}\n        ]\n    }]\n\n    text_prompt = processor.apply_chat_template(\n        convers
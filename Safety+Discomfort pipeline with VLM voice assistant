    "# ===============================\n",
    "# HCRI FUNCTIONS\n",
    "# ===============================\n",
    "def compute_hcri(safety_label, discomfort_label):\n",
    "\n",
    "    safety_map = {\n",
    "        \"Safe\": 0,\n",
    "        \"Risky\": 0.5,\n",
    "        \"Unsafe\": 1\n",
    "    }\n",
    "\n",
    "    discomfort_map = {\n",
    "        \"Comfortable\": 0,\n",
    "        \"Mild_Discomfort\": 0.5,\n",
    "        \"Severe_Discomfort\": 1\n",
    "    }\n",
    "\n",
    "    s = safety_map.get(safety_label, 0)\n",
    "    d = discomfort_map.get(discomfort_label, 0)\n",
    "\n",
    "    hcri = 0.7 * s + 0.3 * d\n",
    "    return round(hcri, 3)\n",
    "\n",
    "\n",
    "def hcri_level(hcri):\n",
    "    if hcri < 0.3:\n",
    "        return f\"{hcri}  → 🟢 Low Risk\"\n",
    "    elif hcri < 0.7:\n",
    "        return f\"{hcri}  → 🟡 Moderate Risk\"\n",
    "    else:\n",
    "        return f\"{hcri}  → 🔴 High Risk\""
